{
  "name": "@piwikpro/vue-piwik-pro",
  "private": false,
  "version": "1.6.0",
  "type": "module",
  "author": "Piwik Pro Integration Team <integrations@piwik.pro>",
  "license": "MIT",
  "description": "Piwik PRO tracking library for VueJS",
  "main": "dist/index.umd.js",
  "module": "dist/index.js",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:docs": "typedoc && concat-md --decrease-title-levels --start-title-level-at=2 docs_raw > README.md && node scripts/postProcessDocs.js",
    "preview": "vite preview",
    "lint": "eslint --ext .js,.vue,.ts src",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "concat-md": "^0.5.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^9.20.1",
    "prettier": "^3.8.1",
    "rollup-plugin-vue": "^6.0.0",
    "typedoc": "^0.27.9",
    "typedoc-plugin-markdown": "^4.4.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vue-tsc": "^3.2.5"
  },
  "keywords": [
    "vue",
    "piwik-pro",
    "analytics",
    "plugin"
  ],
  "dependencies": {
    "@piwikpro/tracking-base-library": "^1.6.0"
  }
}
